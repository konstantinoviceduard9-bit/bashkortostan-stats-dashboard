PORT=4100

# Прямые ссылки на CSV-файлы официальных источников.
# Формат CSV описан в README.md.
BDMO_FLAT_CSV_URL=
ROSSTAT_CSV_URL=
BASHSTAT_CSV_URL=
BUDGET_OPEN_DATA_CSV_URL=

# Базовый URL облачного архива для данных до 2024 года.
# Файлы ожидаются по схеме: <VITE_ARCHIVE_DATA_URL>/<year>/<indicatorId>.json
VITE_ARCHIVE_DATA_URL=

# Live-режим: запросы к /api/live/* (нужен запущенный API: npm run dev:api).
# В dev включён автоматически; на GitHub Pages задайте VITE_ENABLE_LIVE_DATA=true и URL backend API.
VITE_ENABLE_LIVE_DATA=
VITE_LIVE_API_URL=
